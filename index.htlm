<script>
// ════════════════════════════════════════════════
// CONFIG
// ════════════════════════════════════════════════
var FORMSPREE   = 'https://formspree.io/f/xreypjje';
var WEBHOOK_URL = 'https://ton-serveur.com/webhook/paypal'; // Remplacer par ton URL tresorier.py

// ════════════════════════════════════════════════
// CURSOR
// ════════════════════════════════════════════════
(function(){
  var c=document.getElementById('cur'),r=document.getElementById('cur-ring');
  if(!c||!r)return;
  var mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;c.style.left=mx+'px';c.style.top=my+'px'},{passive:true});
  (function tick(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;r.style.left=rx+'px';r.style.top=ry+'px';requestAnimationFrame(tick)})();
})();

// ════════════════════════════════════════════════
// NAV + MENU
// ════════════════════════════════════════════════
window.addEventListener('scroll',function(){document.getElementById('nav').classList.toggle('scrolled',window.scrollY>60);},{passive:true});
function toggleMenu(){var b=document.getElementById('burger'),m=document.getElementById('mobMenu');var o=m.classList.toggle('open');b.classList.toggle('open',o);document.body.style.overflow=o?'hidden':'';}
function closeMob(){document.getElementById('burger').classList.remove('open');document.getElementById('mobMenu').classList.remove('open');document.body.style.overflow='';}
document.addEventListener('click',function(e){var m=document.getElementById('mobMenu'),b=document.getElementById('burger');if(m&&b&&m.classList.contains('open')&&!m.contains(e.target)&&!b.contains(e.target))closeMob();});
document.querySelectorAll('a[href^="#"]').forEach(function(a){
  a.addEventListener('click',function(e){
    var id=a.getAttribute('href');
    if(!id||id==='#'||id==='#top'){e.preventDefault();closeMob();window.scrollTo({top:0,behavior:'smooth'});return;}
    var el=document.querySelector(id);
    if(el){e.preventDefault();closeMob();var nh=parseInt(getComputedStyle(document.documentElement).getPropertyValue('--nav-h'))||64;window.scrollTo({top:el.getBoundingClientRect().top+window.scrollY-nh,behavior:'smooth'});}
  });
});

// ════════════════════════════════════════════════
// REVEAL + COUNTERS
// ════════════════════════════════════════════════
var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');if(e.target.classList.contains('proof-item')){e.target.classList.add('visible');animNum(e.target);}}});},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.rv,.rvl,.proof-item').forEach(function(el){obs.observe(el);});
function animNum(el){var s=el.querySelector('[data-target]');if(!s||s.dataset.done)return;s.dataset.done=1;var tgt=+s.dataset.target,sfx=s.dataset.suffix||'',dur=1400,t0=performance.now();(function tick(now){var p=Math.min((now-t0)/dur,1),v=Math.round(p*p*(3-2*p)*tgt);s.textContent=v+sfx;if(p<1)requestAnimationFrame(tick);})(t0);}

// ════════════════════════════════════════════════
// ÉTAT PAIEMENT
// ════════════════════════════════════════════════
var order = {
  mode: 'abonnement',  // 'abonnement' | 'pack'
  packName: null, packPrice: 0,
  subName: null, subPrice: 0,
  get hasPackPreset(){ return this.mode === 'pack'; }
};
var ppRendered = false;
var hostedFields = null;

function fmt(n){ return n.toFixed(2).replace('.',',') + ' €'; }
function tva(n){ return Math.round(n * 0.20 * 100) / 100; }
function ttc(n){ return Math.round((n + tva(n)) * 100) / 100; }

// ════════════════════════════════════════════════
// OUVRIR / FERMER PAGE PAIEMENT
// ════════════════════════════════════════════════
function openPay(mode, preset) {
  order.mode = mode;
  order.packName = null; order.packPrice = 0;
  order.subName = null; order.subPrice = 0;

  // Reset sélections visuelles
  document.querySelectorAll('.pack-choice,.sub-choice').forEach(function(el){el.classList.remove('selected');});
  document.querySelectorAll('.renew-opt').forEach(function(el){el.classList.remove('selected');});
  document.getElementById('step1-next').disabled = true;

  // Mode pack : montrer le choix de pack, présélectionner si fourni
  var packSec = document.getElementById('pack-section');
  var subTtl  = document.getElementById('sub-section-ttl');
  if(mode === 'pack') {
    packSec.style.display = 'block';
    subTtl.textContent = 'Choisissez votre abonnement mensuel';
    if(preset === 'Stone') selectPack('Stone', 1200, true);
    if(preset === 'Premium') selectPack('Premium', 1800, true);
  } else {
    packSec.style.display = 'none';
    subTtl.textContent = 'Choisissez votre abonnement mensuel';
    if(preset === 'Solo') selectSub('Solo', 49.99, true);
    if(preset === 'Agence') selectSub('Agence', 199.99, true);
    if(preset === 'Grand Compte') selectSub('Grand Compte', 499.99, true);
  }

  goStep1();
  document.getElementById('pay-page').classList.add('open');
  document.body.style.overflow = 'hidden';
  window.scrollTo(0,0);
}

function closePay() {
  document.getElementById('pay-page').classList.remove('open');
  document.body.style.overflow = '';
}

// ════════════════════════════════════════════════
// SÉLECTIONS ÉTAPE 1
// ════════════════════════════════════════════════
function selectPack(name, price, silent) {
  order.packName = name; order.packPrice = price;
  document.querySelectorAll('.pack-choice').forEach(function(el){el.classList.remove('selected');});
  var el = document.getElementById('pc-' + name.toLowerCase());
  if(el) el.classList.add('selected');
  updateRecap();
  checkStep1();
}

function selectSub(name, price, silent) {
  order.subName = name; order.subPrice = price;
  document.querySelectorAll('.sub-choice').forEach(function(el){el.classList.remove('selected');});
  var ids = {'Solo':'sc-solo','Agence':'sc-agence','Grand Compte':'sc-grand'};
  var el = document.getElementById(ids[name]);
  if(el) el.classList.add('selected');
  updateRecap();
  checkStep1();
}

function checkStep1() {
  var ok = (order.mode === 'pack') ? (order.packName && order.subName) : !!order.subName;
  document.getElementById('step1-next').disabled = !ok;
}

function updateRecap() {
  var total = order.packPrice + order.subPrice;
  var tv    = total > 0 ? tva(total) : 0;
  var tc    = total > 0 ? ttc(total) : 0;

  // Titre
  var ttl = order.subName || '—';
  if(order.packName) ttl = 'Pack ' + order.packName + ' + ' + (order.subName || '...');
  document.getElementById('rec-ttl').textContent = ttl;

  // Ligne pack
  var packRow = document.getElementById('rec-pack-row');
  if(order.packName) {
    packRow.style.display = 'flex';
    document.getElementById('rec-pack-lbl').textContent = 'Pack ' + order.packName;
    document.getElementById('rec-pack-val').textContent = fmt(order.packPrice);
  } else {
    packRow.style.display = 'none';
  }

  // Ligne sub
  document.getElementById('rec-sub-val').textContent = order.subName ? fmt(order.subPrice) + '/mois' : '—';
  document.getElementById('rec-sub').textContent = order.subName ? (order.subName + ' · ' + fmt(order.subPrice) + '/mois') : 'Sélectionnez une formule';

  // Total
  var tvaRow   = document.getElementById('rec-tva-row');
  var totalRow = document.getElementById('rec-total-row');
  if(total > 0) {
    tvaRow.style.display = 'flex'; totalRow.style.display = 'flex';
    document.getElementById('rec-tva').textContent = fmt(tv);
    document.getElementById('rec-total').textContent = fmt(tc);
  } else {
    tvaRow.style.display = 'none'; totalRow.style.display = 'none';
  }
}

// ════════════════════════════════════════════════
// NAVIGATION ENTRE ÉTAPES
// ════════════════════════════════════════════════
function goStep1() {
  document.getElementById('step1-panel').style.display = 'block';
  document.getElementById('step2-panel').style.display = 'none';
  document.getElementById('pstep1').classList.add('active');
  document.getElementById('pstep1').classList.remove('done');
  document.getElementById('pstep2').classList.remove('active','done');
  document.getElementById('pstep1-num').textContent = '1';
}

function goStep2() {
  if(document.getElementById('step1-next').disabled) return;
  document.getElementById('step1-panel').style.display = 'none';
  document.getElementById('step2-panel').style.display = 'block';
  document.getElementById('pstep1').classList.remove('active');
  document.getElementById('pstep1').classList.add('done');
  document.getElementById('pstep1-num').textContent = '✓';
  document.getElementById('pstep2').classList.add('active');

  // Scroll haut
  document.getElementById('pay-page').scrollTo(0, 0);

  switchTab('paypal');
  renderPayPalButtons();
}

// ════════════════════════════════════════════════
// ONGLETS MÉTHODE
// ════════════════════════════════════════════════
function switchTab(tab) {
  document.getElementById('tab-paypal').classList.toggle('active', tab==='paypal');
  document.getElementById('tab-card').classList.toggle('active', tab==='card');
  document.getElementById('panel-paypal').style.display = tab==='paypal' ? 'block' : 'none';
  document.getElementById('panel-card').style.display   = tab==='card'   ? 'block' : 'none';
  if(tab==='card') renderHostedFields();
}

// ════════════════════════════════════════════════
// MONTANT TOTAL COMMANDE
// ════════════════════════════════════════════════
function getOrderTotal() {
  return ttc(order.packPrice + order.subPrice);
}
function getOrderDesc() {
  if(order.packName) return 'Pack ' + order.packName + ' + Abonnement ' + order.subName;
  return 'Abonnement StarckKey ' + order.subName;
}

// ════════════════════════════════════════════════
// PAYPAL BUTTONS
// ════════════════════════════════════════════════
function renderPayPalButtons() {
  var container = document.getElementById('paypal-btn-container');
  container.innerHTML = '';
  if(typeof paypal === 'undefined') {
    container.innerHTML = '<p style="color:var(--ink-mute);font-size:13px;font-family:\'DM Mono\',monospace">⚠️ SDK PayPal non chargé. Vérifiez votre connexion.</p>';
    return;
  }
  paypal.Buttons({
    style:{layout:'vertical',color:'blue',shape:'rect',label:'pay',height:46},
    createOrder: function(data, actions) {
      return actions.order.create({
        purchase_units:[{
          description: getOrderDesc(),
          amount:{
            value: getOrderTotal().toFixed(2), currency_code:'EUR',
            breakdown:{
              item_total:{value:(order.packPrice+order.subPrice).toFixed(2),currency_code:'EUR'},
              tax_total:{value:tva(order.packPrice+order.subPrice).toFixed(2),currency_code:'EUR'}
            }
          },
          items:[{name:getOrderDesc(),unit_amount:{value:(order.packPrice+order.subPrice).toFixed(2),currency_code:'EUR'},quantity:'1',category:'DIGITAL_GOODS'}]
        }],
        application_context:{brand_name:'StarckKey',locale:'fr-FR',shipping_preference:'NO_SHIPPING'}
      });
    },
    onApprove: function(data, actions) {
      return actions.order.capture().then(function(details) {
        showSuccess(details);
        notifyBackend(details.id, details);
      });
    },
    onError: function(err) {
      document.getElementById('pay-error').textContent = 'Erreur PayPal. Réessayez ou utilisez la carte.';
      document.getElementById('pay-error').style.display = 'block';
    }
  }).render('#paypal-btn-container');
}

// ════════════════════════════════════════════════
// HOSTED FIELDS (carte)
// ════════════════════════════════════════════════
function renderHostedFields() {
  if(hostedFields || typeof paypal === 'undefined' || !paypal.HostedFields) return;
  paypal.HostedFields.render({
    createOrder: function(){
      return fetch('/api/orders',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({amount:getOrderTotal().toFixed(2),currency:'EUR',description:getOrderDesc()})})
        .then(r=>r.json()).then(d=>d.orderID);
    },
    styles:{'input':{'font-size':'14px','font-family':'Inter,sans-serif','color':'#0D1B3E'},':focus':{'color':'#1C3A7A'},'.invalid':{'color':'#c0392b'}},
    fields:{number:{selector:'#card-number',placeholder:'4111 1111 1111 1111'},expirationDate:{selector:'#card-expiry',placeholder:'MM/AA'},cvv:{selector:'#card-cvv',placeholder:'123'}}
  }).then(function(hf){ hostedFields = hf; }).catch(function(e){ console.warn('HF:', e); });
}

async function cardPay() {
  if(!hostedFields){document.getElementById('pay-error').textContent='Chargement…';document.getElementById('pay-error').style.display='block';return;}
  var btn=document.getElementById('card-pay-btn'),txt=document.getElementById('card-pay-txt');
  var name=document.getElementById('card-name').value.trim();
  if(!name){document.getElementById('pay-error').textContent='Entrez le nom du titulaire.';document.getElementById('pay-error').style.display='block';return;}
  btn.disabled=true;txt.textContent='Traitement…';
  try{
    var p=await hostedFields.submit({cardholderName:name});
    var r=await fetch('/api/orders/'+p.orderId+'/capture',{method:'POST'});
    var d=await r.json();
    showSuccess(d); notifyBackend(d.id||p.orderId,d);
  }catch(e){
    document.getElementById('pay-error').textContent='Paiement refusé : '+(e.message||'Vérifiez vos informations.');
    document.getElementById('pay-error').style.display='block';
    btn.disabled=false;txt.textContent='Confirmer et payer →';
  }
}

// ════════════════════════════════════════════════
// SUCCÈS
// ════════════════════════════════════════════════
function showSuccess(details) {
  closePay();
  var payer = details.payer || {};
  var desc = order.packName ? 'Pack ' + order.packName : '—';
  document.getElementById('s-product').textContent = desc;
  document.getElementById('s-sub').textContent     = 'Abonnement ' + (order.subName||'—') + ' · ' + fmt(order.subPrice) + '/mois';
  document.getElementById('s-amount').textContent  = fmt(getOrderTotal());
  document.getElementById('s-ref').textContent     = details.id || '—';
  document.getElementById('success-page').classList.add('show');
  document.body.style.overflow = 'hidden';
  window.scrollTo(0,0);
}

// ════════════════════════════════════════════════
// NOTIFICATION BACKEND
// ════════════════════════════════════════════════
async function notifyBackend(orderId, details) {
  try {
    await fetch(WEBHOOK_URL + '/notify', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        order_id: orderId,
        product: getOrderDesc(),
        pack: order.packName || null,
        abonnement: order.subName,
        amount: getOrderTotal(),
        email: details?.payer?.email_address || ''
      })
    });
  } catch(e) { /* webhook PayPal prend le relais */ }
}

// ════════════════════════════════════════════════
// PAGE RENOUVELLEMENT
// ════════════════════════════════════════════════
var renewOrder = { name: null, price: 0 };
var renewPPRendered = false;

function openRenew(clientKey, currentPlan, expireDate) {
  // Appelée depuis le lien dans l'email de renouvellement
  // Ex: openRenew('SK-4821-B7F2-C193', 'Agence', '15/02/2026')
  clientKey   = clientKey   || 'SK-XXXX-XXXX-XXXX';
  currentPlan = currentPlan || 'Agence';
  expireDate  = expireDate  || '—';

  document.getElementById('renew-key-display').textContent   = clientKey;
  document.getElementById('renew-current-plan').textContent  = currentPlan;
  document.getElementById('renew-expire-date').textContent   = expireDate;

  // Marquer la formule actuelle
  document.querySelectorAll('.renew-opt').forEach(function(el){
    el.classList.remove('current-plan','selected');
  });
  var planMap = {'Solo':'ro-solo','Agence':'ro-agence','Grand Compte':'ro-grand'};
  var current = document.getElementById(planMap[currentPlan]);
  if(current) current.classList.add('current-plan');

  renewOrder = {name: null, price: 0};
  renewPPRendered = false;
  document.getElementById('renew-paypal-container').innerHTML = '';
  document.getElementById('renew-pay-error').style.display = 'none';
  document.getElementById('resil-confirm').style.display = 'none';

  document.getElementById('renew-page').classList.add('show');
  document.body.style.overflow = 'hidden';
}

function closeRenew() {
  document.getElementById('renew-page').classList.remove('show');
  document.body.style.overflow = '';
}

function selectRenewOpt(name, price) {
  renewOrder = {name, price};
  document.querySelectorAll('.renew-opt').forEach(function(el){el.classList.remove('selected');});
  var ids = {'Solo':'ro-solo','Agence':'ro-agence','Grand Compte':'ro-grand'};
  var el = document.getElementById(ids[name]);
  if(el) el.classList.add('selected');
  document.getElementById('renew-card-btn').disabled = false;
  renderRenewPayPal();
}

function switchRenewTab(tab) {
  document.getElementById('rtab-paypal').classList.toggle('active', tab==='paypal');
  document.getElementById('rtab-card').classList.toggle('active', tab==='card');
  document.getElementById('renew-panel-paypal').style.display = tab==='paypal' ? 'block' : 'none';
  document.getElementById('renew-panel-card').style.display   = tab==='card'   ? 'block' : 'none';
}

function renderRenewPayPal() {
  var container = document.getElementById('renew-paypal-container');
  container.innerHTML = '';
  if(!renewOrder.name || typeof paypal === 'undefined') return;
  var total = ttc(renewOrder.price);
  paypal.Buttons({
    style:{layout:'vertical',color:'blue',shape:'rect',label:'pay',height:46},
    createOrder: function(data, actions) {
      return actions.order.create({
        purchase_units:[{
          description:'Renouvellement StarckKey — ' + renewOrder.name,
          amount:{value:total.toFixed(2),currency_code:'EUR',breakdown:{item_total:{value:renewOrder.price.toFixed(2),currency_code:'EUR'},tax_total:{value:tva(renewOrder.price).toFixed(2),currency_code:'EUR'}}}
        }],
        application_context:{brand_name:'StarckKey',locale:'fr-FR',shipping_preference:'NO_SHIPPING'}
      });
    },
    onApprove: function(data, actions) {
      return actions.order.capture().then(function(details) {
        showRenewSuccess(details, renewOrder.name, total);
      });
    },
    onError: function(err) {
      document.getElementById('renew-pay-error').textContent = 'Erreur PayPal. Réessayez.';
      document.getElementById('renew-pay-error').style.display = 'block';
    }
  }).render('#renew-paypal-container');
}

function renewCardPay() {
  // Même logique que cardPay() mais via la page renew — simplifié ici
  alert('Paiement par carte : disponible après configuration des Hosted Fields sur votre serveur.');
}

function showRenewSuccess(details, planName, total) {
  closeRenew();
  var payer = details.payer || {};
  order.subName = planName; order.subPrice = renewOrder.price;
  order.packName = null; order.packPrice = 0;
  document.getElementById('s-product').textContent = 'Renouvellement';
  document.getElementById('s-sub').textContent     = 'Abonnement ' + planName + ' · ' + fmt(renewOrder.price) + '/mois';
  document.getElementById('s-amount').textContent  = fmt(total);
  document.getElementById('s-ref').textContent     = details.id || '—';
  document.getElementById('success-page').classList.add('show');
  document.body.style.overflow = 'hidden';
}

function showResilConfirm() {
  document.getElementById('resil-confirm').style.display = 'block';
}
function hideResilConfirm() {
  document.getElementById('resil-confirm').style.display = 'none';
}
function confirmResil() {
  closeRenew();
  alert('Votre demande de résiliation a été enregistrée. Vous recevrez un email de confirmation. Votre accès reste actif jusqu\'à la date d\'expiration.');
  // En production : appel API backend pour marquer la résiliation
}

// ════════════════════════════════════════════════
// Lecture URL params pour ouverture auto renouvellement
// Ex: starckkey.com?action=renew&key=SK-XXXX&plan=Agence&expire=15/02/2026
// ════════════════════════════════════════════════
(function(){
  var params = new URLSearchParams(window.location.search);
  if(params.get('action') === 'renew') {
    setTimeout(function(){
      openRenew(params.get('key'), params.get('plan'), params.get('expire'));
    }, 300);
  }
})();

// ════════════════════════════════════════════════
// CONTACT FORM
// ════════════════════════════════════════════════
async function sendForm(){
  var btn=document.getElementById('fsub'),txt=document.getElementById('fsubtxt'),err=document.getElementById('ferr');
  var agence=document.getElementById('fa').value.trim(),nom=document.getElementById('fn').value.trim();
  var email=document.getElementById('fe').value.trim(),tel=document.getElementById('ft').value.trim();
  var msg=document.getElementById('fm').value.trim();
  err.style.display='none';
  if(!agence||!nom||!email||!tel||!msg){err.textContent='Veuillez remplir tous les champs.';err.style.display='block';return;}
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){err.textContent='Email invalide.';err.style.display='block';return;}
  btn.disabled=true;txt.textContent='Envoi…';
  try{
    var res=await fetch(FORMSPREE,{method:'POST',headers:{'Accept':'application/json','Content-Type':'application/json'},body:JSON.stringify({agence,nom,email,telephone:tel,message:msg,_subject:'💬 Message StarckKey — '+agence,_replyto:email})});
    if(res.ok){document.getElementById('fwrap').style.display='none';document.getElementById('fok').style.display='block';}
    else throw new Error();
  }catch(e){err.textContent='Erreur. Écrivez à contact.starck.empire@gmail.com';err.style.display='block';btn.disabled=false;txt.textContent='Envoyer →';}
}

// ESC
document.addEventListener('keydown',function(e){
  if(e.key==='Escape'){
    closePay();
    closeRenew();
  }
});
</script>

</body>
</html>